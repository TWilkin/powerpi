{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/TWilkin/powerpi/main/services/config-server/schema/common/Condition.schema.json",
    "title": "Condition",
    "description": "A condition using the PowerPi JSON condition expression",
    "$ref": "#/$defs/expression",

    "$defs": {
        "constant": {
            "description": "A constant value",
            "oneOf": [
                { "type": ["boolean"] },
                { "type": ["number"] },
                { "type": ["integer"] },
                { "type": ["string"] },
                { "type": "null" }
            ]
        },
        "identifier": {
            "description": "An identifier",
            "type": "object",
            "properties": {
                "var": {
                    "type": "string",
                    "pattern": "^(device\\.\\w+\\.\\w+)|(sensor\\.\\w+.\\w+.\\w+)|(presence\\.\\w+\\.state)|(geofence\\.\\w+\\.state)|(message\\.\\w+)$"
                }
            },
            "additionalProperties": false
        },
        "expression": {
            "description": "An expression; logical, equality, relational, arithmetic",
            "type": "object",
            "properties": {
                "not": { "$ref": "#/$defs/unary_expression_body" },
                "!": { "$ref": "#/$defs/unary_expression_body" },
                "equals": { "$ref": "#/$defs/comparison_expression_body" },
                "greater_than": { "$ref": "#/$defs/comparison_expression_body" },
                ">": { "$ref": "#/$defs/comparison_expression_body" },
                "greater_than_equal": { "$ref": "#/$defs/comparison_expression_body" },
                ">=": { "$ref": "#/$defs/comparison_expression_body" },
                "less_than": { "$ref": "#/$defs/comparison_expression_body" },
                "<": { "$ref": "#/$defs/comparison_expression_body" },
                "less_than_equal": { "$ref": "#/$defs/comparison_expression_body" },
                "<=": { "$ref": "#/$defs/comparison_expression_body" },
                "and": { "$ref": "#/$defs/logical_expression_body" },
                "&": { "$ref": "#/$defs/logical_expression_body" },
                "when": { "$ref": "#/$defs/logical_expression_body" },
                "or": { "$ref": "#/$defs/logical_expression_body" },
                "|": { "$ref": "#/$defs/logical_expression_body" },
                "either": { "$ref": "#/$defs/logical_expression_body" },
                "add": { "$ref": "#/$defs/arithmetic_expression_body" },
                "+": { "$ref": "#/$defs/arithmetic_expression_body" },
                "subtract": { "$ref": "#/$defs/arithmetic_expression_body" },
                "-": { "$ref": "#/$defs/arithmetic_expression_body" },
                "multiply": { "$ref": "#/$defs/arithmetic_expression_body" },
                "*": { "$ref": "#/$defs/arithmetic_expression_body" },
                "divide": { "$ref": "#/$defs/arithmetic_expression_body" },
                "/": { "$ref": "#/$defs/arithmetic_expression_body" }
            },
            "additionalProperties": false,
            "oneOf": [
                { "required": ["not"] },
                { "required": ["!"] },
                { "required": ["equals"] },
                { "required": ["greater_than"] },
                { "required": [">"] },
                { "required": ["greater_than_equal"] },
                { "required": [">="] },
                { "required": ["less_than"] },
                { "required": ["<"] },
                { "required": ["less_than_equal"] },
                { "required": ["<="] },
                { "required": ["and"] },
                { "required": ["&"] },
                { "required": ["when"] },
                { "required": ["or"] },
                { "required": ["|"] },
                { "required": ["either"] },
                { "required": ["add"] },
                { "required": ["+"] },
                { "required": ["subtract"] },
                { "required": ["-"] },
                { "required": ["multiply"] },
                { "required": ["*"] },
                { "required": ["divide"] },
                { "required": ["/"] }
            ]
        },
        "expression_body": {
            "description": "The body of an expression; logical, equality, relational, arithmetic",
            "type": "array",
            "items": {
                "oneOf": [
                    { "$ref": "#/$defs/expression" },
                    { "$ref": "#/$defs/constant" },
                    { "$ref": "#/$defs/identifier" }
                ]
            }
        },
        "unary_expression_body": {
            "description": "The body of a unary expression: not a",
            "oneOf": [
                { "$ref": "#/$defs/expression" },
                { "$ref": "#/$defs/constant" },
                { "$ref": "#/$defs/identifier" }
            ]
        },
        "arithmetic_expression_body": {
            "description": "The body of an arithmetic expression: a + b",
            "type": "array",
            "minItems": 2,
            "$ref": "#/$defs/expression_body"
        },
        "comparison_expression_body": {
            "description": "The body of a comparison expression: a >= b",
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "$ref": "#/$defs/expression_body"
        },
        "logical_expression_body": {
            "description": "The body of a logical expression: a and b",
            "type": "array",
            "minItems": 1,
            "$ref": "#/$defs/expression_body"
        }
    }
}
