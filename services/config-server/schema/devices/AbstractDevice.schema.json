{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/TWilkin/powerpi/main/services/config-server/schema/devices/AbstractDevice.schema.json",
    "title": "AbstractDevice",
    "description": "The common properties for all devices or sensors in PowerPi",
    "type": "object",
    "properties": {
        "name": {
            "description": "The name of this device",
            "$ref": "https://raw.githubusercontent.com/TWilkin/powerpi/main/services/config-server/schema/common/Identifier.schema.json"
        },
        "display_name": {
            "description": "The display name of this device",
            "type": "string"
        },
        "type": {
            "description": "The type of the device or sensor",
            "type": "string"
        }
    },
    "required": ["name", "type"]
}
